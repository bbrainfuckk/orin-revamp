# Firebase web app (public browser configuration)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=orin-ai-502503.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=orin-ai-502503
VITE_FIREBASE_STORAGE_BUCKET=orin-ai-502503.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=277254919824
VITE_FIREBASE_APP_ID=

# Firebase server access. Store only in Vercel production/preview secrets.
FIREBASE_PROJECT_ID=orin-ai-502503
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=

# Connector security. Generate separate random values; never expose as VITE_*.
OAUTH_STATE_SECRET=
CONNECTOR_ENCRYPTION_KEY=
WIDGET_SIGNING_SECRET=

# Server-side AI inference. Never expose as VITE_*.
CEREBRAS_API_KEY=
CEREBRAS_MODEL=gpt-oss-120b

# Meta app and webhook
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v24.0
META_REDIRECT_URI=https://www.orin.work/api/integrations/meta/callback
META_SCOPES=pages_show_list,pages_messaging,pages_manage_metadata,pages_read_engagement,instagram_basic,instagram_manage_messages
META_WEBHOOK_VERIFY_TOKEN=
# WhatsApp Embedded Signup configuration created in the same Meta app.
META_WHATSAPP_CONFIG_ID=
# May reuse META_WEBHOOK_VERIFY_TOKEN when both products target the same verified handler.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Future provider authorization (partner approval may also be required)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://www.orin.work/api/integrations/tiktok/callback
# Set true only after the TikTok Developer Portal callback targets /api/webhooks/tiktok.
TIKTOK_WEBHOOKS_CONFIGURED=false
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
# Current seller authorization callback. Shopee Customer Service App approval is required.
SHOPEE_REDIRECT_URI=https://www.orin.work/api/integrations/shopee/callback
# The exact callback URL is part of Shopee's push signature and must match the Console value byte-for-byte.
SHOPEE_WEBHOOK_URL=https://www.orin.work/api/webhooks/shopee
# Set true only after Webchat Push (code 10) is enabled for the approved app.
SHOPEE_WEBHOOKS_CONFIGURED=false
# Optional overrides for sandbox/region-specific testing. Production defaults are used when blank.
SHOPEE_AUTH_URL=https://open.shopee.com/auth
SHOPEE_API_HOST=https://partner.shopeemobile.com
LAZADA_APP_KEY=
LAZADA_APP_SECRET=
LAZADA_REDIRECT_URI=https://www.orin.work/api/integrations/lazada/callback
# Set true only after the Lazada Open Platform push URL targets /api/webhooks/lazada.
LAZADA_WEBHOOKS_CONFIGURED=false
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_REDIRECT_URI=https://www.orin.work/api/integrations/shopify/callback
SHOPIFY_SCOPES=read_orders,read_customers,read_products
SHOPIFY_API_VERSION=2026-07
# Set true only after app-specific HTTPS subscriptions target /api/webhooks/shopify.
SHOPIFY_WEBHOOKS_CONFIGURED=false

# Public lead delivery
SHEET_WEBHOOK_URL=
