rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function membership(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    function isMember(workspaceId) {
      return signedIn()
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    function canEdit(workspaceId) {
      return isMember(workspaceId)
        && membership(workspaceId).data.role in ['owner', 'admin', 'editor'];
    }

    function canAdmin(workspaceId) {
      return isMember(workspaceId)
        && membership(workspaceId).data.role in ['owner', 'admin'];
    }

    function safeClientConnection(data) {
      return data.provider in ['meta', 'tiktok', 'shopee', 'lazada', 'shopify', 'airbnb', 'website', 'n8n']
        && data.status in ['authorization_required', 'configuration_required', 'access_review']
        && data.credentialState == 'not_supplied'
        && (data.health == 'not_tested' || (data.provider == 'n8n' && data.health == 'test_passed'))
        && !data.keys().hasAny([
          'accessToken',
          'refreshToken',
          'clientSecret',
          'ciphertext',
          'iv',
          'authorizationStatus',
          'pageIds',
          'instagramAccountIds'
        ]);
    }

    match /users/{userId} {
      allow create, read, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /workspaces/{workspaceId} {
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow read: if isMember(workspaceId);
      allow update, delete: if canAdmin(workspaceId);

      match /members/{memberId} {
        allow read: if isMember(workspaceId);
        allow create: if canAdmin(workspaceId)
          || (signedIn()
            && memberId == request.auth.uid
            && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid
            && request.resource.data.role == 'owner');
        allow update, delete: if canAdmin(workspaceId);
      }

      match /connectorVault/{secretId} {
        allow read, write: if false;
      }

      match /connections/{connectionId} {
        allow read: if isMember(workspaceId);
        allow create, update: if canEdit(workspaceId) && safeClientConnection(request.resource.data);
        allow delete: if canAdmin(workspaceId);
      }

      match /{collectionName}/{documentId} {
        allow read: if collectionName != 'connectorVault'
          && collectionName != 'connections'
          && isMember(workspaceId);
        allow create, update: if collectionName != 'connectorVault'
          && collectionName != 'connections'
          && canEdit(workspaceId);
        allow delete: if collectionName != 'connectorVault'
          && collectionName != 'connections'
          && canAdmin(workspaceId);

        match /{nestedCollection}/{nestedDocument} {
          allow read: if collectionName != 'connectorVault' && isMember(workspaceId);
          allow create, update: if collectionName != 'connectorVault' && canEdit(workspaceId);
          allow delete: if collectionName != 'connectorVault' && canAdmin(workspaceId);
        }
      }
    }
  }
}
