rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function membership(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    function isMember(workspaceId) {
      return signedIn()
        && exists(/databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid));
    }

    function canEdit(workspaceId) {
      return isMember(workspaceId)
        && membership(workspaceId).data.role in ['owner', 'admin', 'editor'];
    }

    function canAdmin(workspaceId) {
      return isMember(workspaceId)
        && membership(workspaceId).data.role in ['owner', 'admin'];
    }

    function isOwner(workspaceId) {
      return isMember(workspaceId) && membership(workspaceId).data.role == 'owner';
    }

    function privateWorkspaceCollection(collectionName) {
      return collectionName in ['connectorVault', 'providerEvents'];
    }

    function serverOwnedCollection(collectionName) {
      return collectionName in ['connectorVault', 'providerEvents', 'contacts', 'conversations', 'events', 'automationRuns', 'tasks', 'notifications'];
    }

    function safeClientConnection(data) {
      return data.provider in ['meta', 'whatsapp', 'tiktok', 'shopee', 'lazada', 'shopify', 'airbnb', 'website', 'n8n']
        && data.status in ['authorization_required', 'configuration_required', 'access_review']
        && data.credentialState == 'not_supplied'
        && (data.health == 'not_tested' || (data.provider == 'n8n' && data.health == 'test_passed'))
        && !data.keys().hasAny([
          'accessToken',
          'refreshToken',
          'clientSecret',
          'ciphertext',
          'iv',
          'authorizationStatus',
          'pageIds',
          'instagramAccountIds'
        ]);
    }

    match /users/{userId} {
      allow create, read, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /connectorRoutes/{routeId} {
      allow read, write: if false;
    }

    match /conversationRoutes/{routeId} {
      allow read, write: if false;
    }

    match /outboundRequests/{requestId} {
      allow read, write: if false;
    }

    match /outboundRateLimits/{bucketId} {
      allow read, write: if false;
    }

    match /publicWidgets/{widgetKey} {
      allow read, write: if false;
    }

    match /widgetRateLimits/{bucketId} {
      allow read, write: if false;
    }

    match /workspaceInvitations/{invitationId} {
      allow read, write: if false;
    }

    match /userWorkspaceMemberships/{membershipId} {
      allow read, write: if false;
    }

    match /workspaces/{workspaceId} {
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow read: if isMember(workspaceId);
      allow update: if canAdmin(workspaceId)
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'updatedAt']);
      allow delete: if isOwner(workspaceId);

      match /members/{memberId} {
        allow read: if isMember(workspaceId);
        allow create: if signedIn()
          && memberId == request.auth.uid
          && get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.ownerId == request.auth.uid
          && request.resource.data.role == 'owner';
        allow update, delete: if false;
      }

      match /notifications/{notificationId} {
        allow read: if isMember(workspaceId) && resource.data.recipientId == request.auth.uid;
        allow write: if false;
      }

      match /connectorVault/{secretId} {
        allow read, write: if false;
      }

      match /providerEvents/{eventId} {
        allow read, write: if false;
      }

      match /connections/{connectionId} {
        allow read: if isMember(workspaceId);
        allow create, update: if canEdit(workspaceId) && safeClientConnection(request.resource.data);
        allow delete: if canAdmin(workspaceId);
      }

      match /{collectionName}/{documentId} {
        allow read: if !privateWorkspaceCollection(collectionName)
          && collectionName != 'connections'
          && collectionName != 'notifications'
          && isMember(workspaceId);
        allow create, update: if !serverOwnedCollection(collectionName)
          && collectionName != 'connections'
          && canEdit(workspaceId);
        allow delete: if !serverOwnedCollection(collectionName)
          && collectionName != 'connections'
          && canAdmin(workspaceId);

        match /{nestedCollection}/{nestedDocument} {
          allow read: if !privateWorkspaceCollection(collectionName) && isMember(workspaceId);
          allow create, update: if !serverOwnedCollection(collectionName) && canEdit(workspaceId);
          allow delete: if !serverOwnedCollection(collectionName) && canAdmin(workspaceId);
        }
      }
    }
  }
}
